<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Rote.MainWindow"
        Title="Rote"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        CanResize="False"
        WindowStartupLocation="Manual">

    <Grid RowDefinitions="56,*" Background="Transparent">

        <!-- Handle — collapsed indicator + drag grip + expand/collapse trigger -->
        <Border x:Name="HandleBorder"
                Grid.Row="0"
                Width="36" Height="36"
                CornerRadius="10"
                Background="#25FFFFFF"
                BorderBrush="#30FFFFFF"
                BorderThickness="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Cursor="SizeAll"
                ZIndex="10">
            <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="3">
                <Border Width="10" Height="1.5" CornerRadius="1"
                        Background="#60FFFFFF"
                        HorizontalAlignment="Center" />
                <Border Width="10" Height="1.5" CornerRadius="1"
                        Background="#60FFFFFF"
                        HorizontalAlignment="Center" />
                <Border Width="10" Height="1.5" CornerRadius="1"
                        Background="#60FFFFFF"
                        HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Note — visible when expanded -->
        <Border x:Name="NoteBorder"
                Grid.Row="1"
                CornerRadius="16"
                Background="#10FFFFFF"
                BorderBrush="#20FFFFFF"
                BorderThickness="1"
                Margin="8,0,8,8"
                ZIndex="1"
                ClipToBounds="True">
            <Grid>
                <TextBox x:Name="NoteEditor"
                         Watermark="随手写点什么……"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         FontSize="15"
                         Foreground="White"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="16,12"
                         VerticalAlignment="Stretch"
                         HorizontalAlignment="Stretch"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" />
                <!-- Resize handle -->
                <Border x:Name="ResizeHandle"
                        Width="16" Height="16"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Cursor="SizeNWSE"
                        Background="Transparent"
                        ZIndex="2">
                    <Path Data="M14,14 L14,6 M14,14 L6,14 M14,14 L10,10 M14,14 L14,10 M14,14 L10,14"
                          Stroke="#60FFFFFF"
                          StrokeThickness="1.5"
                          Stretch="Uniform" />
                </Border>
            </Grid>
        </Border>

    </Grid>

</Window>
